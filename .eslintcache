ontact-title\">Contact Info</div>\r\n        <div className=\"contact-text\">\r\n          <div className=\"mb-3\">\r\n            <FontAwesomeIcon\r\n              className=\"contact-fa-circle\"\r\n              icon={faCircle}\r\n              size=\"3x\"\r\n              fixedWidth\r\n            />\r\n            <FontAwesomeIcon\r\n              className=\"contact-fa-inner\"\r\n              icon={faPhoneAlt}\r\n              size=\"2x\"\r\n              fixedWidth\r\n            />\r\n            <h2 style={{ display: \"inline\" }}> 0947575314</h2>\r\n          </div>\r\n          <div className=\"mb-3\">\r\n            <FontAwesomeIcon\r\n              className=\"contact-fa-circle\"\r\n              icon={faCircle}\r\n              size=\"3x\"\r\n              fixedWidth\r\n            />\r\n            <FontAwesomeIcon\r\n              className=\"contact-fa-inner\"\r\n              icon={faEnvelope}\r\n              size=\"2x\"\r\n              fixedWidth\r\n            />\r\n\r\n            <h2 style={{ display: \"inline\" }}>\r\n              {\" \"}\r\n              Boutrous.m.tawaifi@gmail.com{\" \"}\r\n            </h2>\r\n          </div>\r\n\r\n          <div className=\"mb-3\">\r\n            <FontAwesomeIcon\r\n              className=\"contact-fa-circle\"\r\n              icon={faCircle}\r\n              size=\"3x\"\r\n              fixedWidth\r\n            />\r\n            <FontAwesomeIcon\r\n              className=\"contact-fa-inner\"\r\n              icon={faMapMarkerAlt}\r\n              size=\"2x\"\r\n              fixedWidth\r\n            />\r\n\r\n            <h2 style={{ display: \"inline\" }}> Aleppo | Syria</h2>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <div className=\"contact-container-icons\">\r\n        <motion.div whileHover={{scale:1.05,transition:{yoyo:Infinity}}} className=\"mb-3\">\r\n          <a\r\n            className=\"contact-text-icons\"\r\n            href=\"https://www.facebook.com/boutro